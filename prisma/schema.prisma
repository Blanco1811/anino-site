datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model MigrationRun {
  id               String           @id @default(cuid())
  runId            String           @unique
  mode             String           // "dry_run", "execute", "rollback"
  status           String           // "started", "completed", "failed", "rolled_back"
  errorMessage     String?
  rollbackOfRunId  String?
  startedAt        DateTime         @default(now())
  finishedAt       DateTime?
  createdBy        String?
  usersCreated     Int              @default(0)
  agentsCreated    Int              @default(0)
  callsCreated     Int              @default(0)
  knowledgeCreated Int              @default(0)
  conflictsCount   Int              @default(0)
  reportJson       String?          // Log conflict details or rollback results
  
  users            User[]
  agents           Agent[]
  calls            Call[]
  knowledge        AgentKnowledge[]
}

model User {
  id                String            @id @default(cuid())
  firstName         String
  lastName          String
  email             String            @unique
  password          String
  phone             String?
  resetToken        String?
  resetTokenExpires DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  legacyAccountId   Int?              @unique
  legacyBalance     Decimal?
  migrationRunId    String?
  migrationRun      MigrationRun?     @relation(fields: [migrationRunId], references: [id])
  
  agents            Agent[]
  whatsappSession   WhatsAppSession?
  businessProfile   BusinessProfile?
  customers         Customer[]

  @@index([migrationRunId])
}

model Agent {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  phoneNumber   String?   // Optional during initial phase (before client numbers are purchased)
  purpose       String
  status        String    @default("waiting")
  tone          String[]  // Supported natively in PostgreSQL
  startTime     String?   // Made optional to support legacy null values
  endTime       String?   // Made optional to support legacy null values
  scheduledAt   DateTime?
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  calls         Call[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  legacyAgentId  Int?              @unique
  imageUrl       String?   // For agent avatar image
  greeting       String?   // Legacy initial agent greeting
  migrationRunId String?
  migrationRun   MigrationRun?     @relation(fields: [migrationRunId], references: [id])
  knowledge      AgentKnowledge[]

  @@index([migrationRunId])
}

model Call {
  id            String    @id @default(cuid())
  agentId       String
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  number        String
  purpose       String
  status        String
  scheduledAt   DateTime?
  startedAt     DateTime? // Made optional to support legacy nulls (no fake timestamps)
  twilioSid     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  legacyCallId            Int?              @unique
  direction               String?
  tries                   Int?
  transcript              String?
  recordingUrl            String?
  retellCallId            String?
  durationSeconds         Int?
  errorMessage            String?
  lastSchedulerAttemptAt  DateTime?
  endedAt                 DateTime?
  migrationRunId          String?
  migrationRun            MigrationRun?     @relation(fields: [migrationRunId], references: [id])

  @@index([migrationRunId])
}

model AgentKnowledge {
  id             String        @id @default(cuid())
  agentId        String
  agent          Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  content        String
  link           String?
  title          String?
  legacyId       Int?          @unique
  migrationRunId String?
  migrationRun   MigrationRun? @relation(fields: [migrationRunId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([migrationRunId])
}

model WhatsAppSession {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionData String?  
  isActive    Boolean  @default(false)
  lastQR      String?  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BusinessProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName          String
  businessType          String
  description           String
  openingHours          String
  address               String
  deliveryAreas         String
  phone                 String
  whatsappNumber        String
  whatsappPhoneNumberId String?  // Meta phone number ID for inbound webhook filtering
  menuText              String
  faqText               String
  agentInstructions     String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Customer {
  id        String    @id @default(cuid())
  userId    String    // Scopes customer to the business owner
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String
  name      String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([phone, userId]) // Enforces phone uniqueness per business owner
}

model Message {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sender     String   // "customer" or "agent"
  text       String
  createdAt  DateTime @default(now())
}
